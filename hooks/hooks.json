{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pet-state.sh hello", "timeout": 5, "async": true },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/claude-pet autostart", "timeout": 120, "async": true }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pet-state.sh thinking", "timeout": 5, "async": true }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pet-state.sh working", "timeout": 5, "async": true }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pet-state.sh done", "timeout": 5, "async": true }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pet-state.sh waiting", "timeout": 5, "async": true }
        ]
      }
    ]
  }
}
