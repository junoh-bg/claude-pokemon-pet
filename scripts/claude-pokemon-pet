#!/bin/bash
# claude-pokemon-pet — Pokémon pet overlay for Claude Code.
# Usage: claude-pokemon-pet [toggle|on|off|random|pet <name>|lang <ko|en|auto>|sprites|status|autostart]

# Homebrew may be missing from PATH when hooks run from GUI-launched apps
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
# Resolve symlinks (e.g. a PATH symlink to this script) before finding ROOT
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"
CACHE="$HOME/.cache/claude-pokemon-pet"
CORE="$ROOT/scripts/pet-core.sh"
mkdir -p "$CACHE"

pid()   { pgrep -f "pet-overlay.js" | head -1; }
stop()  { pkill -f "pet-overlay.js" 2>/dev/null; echo "overlay: off"; }

# Spawn exactly one overlay. mkdir is atomic, so when two sessions' hooks race
# only one wins the lock — prevents two overlays stacking on top of each other.
launch() {
    local lock="$CACHE/.launch.lock"
    if [ -d "$lock" ]; then   # clear a lock leaked by a killed process
        # (a failed stat means the lock vanished mid-check — not staleness)
        local mtime
        if mtime=$(stat -f %m "$lock" 2>/dev/null || stat -c %Y "$lock" 2>/dev/null) && [ -n "$mtime" ]; then
            [ $(( $(date +%s) - mtime )) -gt 30 ] && rmdir "$lock" 2>/dev/null
        fi
    fi
    mkdir "$lock" 2>/dev/null || return 0   # another launch already in progress
    if [ -z "$(pid)" ]; then
        nohup osascript -l JavaScript "$ROOT/scripts/pet-overlay.js" "$ROOT" >/dev/null 2>&1 &
        sleep 0.5   # let it register so a concurrent caller sees the pid
    fi
    rmdir "$lock" 2>/dev/null
}

start() {
    for dep in jq gifsicle osascript; do
        command -v "$dep" >/dev/null || { echo "claude-pokemon-pet: missing dependency: $dep (brew install jq gifsicle)" >&2; exit 1; }
    done
    [ -f "$CACHE/sprites-big/mew.gif" ] || "$ROOT/scripts/get-sprites.sh"
    # Daily gacha: roll a new partner on the first start of the day.
    # The partner never changes while the overlay is running.
    "$CORE" roll-if-new-day
    launch
    echo "overlay: on"
}

case "${1:-toggle}" in
    toggle)    if [ -n "$(pid)" ]; then touch "$CACHE/off"; stop; else rm -f "$CACHE/off"; start; fi ;;
    on)        rm -f "$CACHE/off"; [ -n "$(pid)" ] || start ;;
    off)       touch "$CACHE/off"; stop ;;
    autostart) [ -f "$CACHE/off" ] || [ -n "$(pid)" ] || start ;;
    random)    "$CORE" roll ;;
    digimon|pokemon) "$CORE" franchise "$1" ;;
    pet)       "$CORE" pick "${2:-}" ;;
    lang)      "$CORE" lang "${2:-}" ;;
    sprites)   exec "$ROOT/scripts/get-sprites.sh" ;;
    term)
        for dep in jq python3; do
            command -v "$dep" >/dev/null || { echo "claude-pokemon-pet term: missing dependency: $dep" >&2; exit 1; }
        done
        if [ ! -f "$CACHE/sprites/mew.gif" ]; then
            command -v curl >/dev/null || { echo "claude-pokemon-pet term: need curl to fetch sprites" >&2; exit 1; }
            "$ROOT/scripts/get-sprites.sh"
        fi
        "$CORE" roll-if-new-day >/dev/null
        exec python3 "$ROOT/scripts/pet-term.py" "$ROOT"
        ;;
    statusline)
        echo "Add this to ~/.claude/settings.json to put the pet in your statusline:"
        echo ''
        echo '  "statusLine": {'
        echo '    "type": "command",'
        echo "    \"command\": \"$ROOT/scripts/pet-statusline.sh\""
        echo '  }'
        echo ''
        echo "Preview: $("$ROOT/scripts/pet-statusline.sh")"
        ;;
    status)
        echo "overlay: $([ -n "$(pid)" ] && echo "on (pid $(pid))" || echo off)"
        "$CORE" status
        ;;
    *)
        echo "usage: claude-pokemon-pet [toggle|on|off|random|digimon|pokemon|pet <name>|lang <ko|en|auto>|term|statusline|sprites|status]" >&2
        exit 1
        ;;
esac
